@inherits DotnetConf2023Model
@page "/publicspeaking/dotnetconf/2023"

<div class="row">
    <div class="col-auto">
        <a href="/publicspeaking" class="button" title="Back"><img alt="back" src="@Config.Images.General.Back" class="button img-fluid" title="Back" /></a>
    </div>
    <div class="col">
        <div class="pagetitle">
            <h1>Microsoft .NET Conference</h1>
            <h2>2023</h2>
            <hr class="pagedivider" />
            <div class="container-fluid" style="margin-top: -50px;">
                <div class="row">
                    <div class="col-sm-4"></div>
                    <div class="col-sm-4">
                        <a href="https://cptmsdug.dev/netconf2023" title=".NET Conference 2023" target="_blank">
                            <div class="mt-3 p-4 px-1 text-white rounded text-center hometile">
                                <img alt=".NET Conference 2023" src="@Config.Images.PublicSpeaking.dotnetConf2023" class="img-fluid" title=".NET Conference 2023" />
                            </div>
                        </a>
                    </div>
                    <div class="col-sm-4"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-sm-2"></div>
    <div class="col-sm-8">
        <h2><b>Infrastructure as Code: The Developer's Secret Weapon</b></h2>
        <h5>In today's fast-paced world of software development, agility and efficiency are paramount. Developers are constantly seeking tools and practices that can help them deliver high-quality software quickly and reliably. Introducing Infrastructure as Code: The Developer's Secret Weapon. In this engaging presentation, we'll delve into the world of IaC and explore how it empowers developers to supercharge their productivity, streamline workflows, and elevate their impact on the development process.</h5>
        <a href="https://sessionize.com/s/henniefrancis/infrastructure-as-code-the-developers-secret-weapo/98255" title="Sessionize Session" target="_blank" class="blanklink">
            <div class="mt-5 p-1 text-white rounded text-center">
                <img alt="Sessionize" src="@Config.Images.Socials.Sessionize" class="img-fluid" style="width: 400px;" title="Sessionize" />
            </div>
        </a>
    </div>
    <div class="col-sm-2"></div>
</div>