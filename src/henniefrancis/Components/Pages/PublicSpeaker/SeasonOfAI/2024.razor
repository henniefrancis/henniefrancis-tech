                    </a>
                </div>
                <div class="col-4">
                    <h3><b>Johannesburg</b></h3>
                    <a href="https://www.youtube.com/watch?v=hlunhsEWPgE&t" title="Sessionize Session" target="_blank" class="blanklink">
                        <img alt="Watch it on YouTube" src="@Config.Images.Socials.YouTubeWatch" class="img-fluid" style="width: 200px;" title="Watch it on YouTube" />
                    </a>
