@page "/preview/{EventName}/{Year}/{PhotoName}"

<img alt="@PhotoName" src="@Image()" class="img-fluid" style="max-width:fit-content; max-height: fit-content" title="@PhotoName" />

@code {
    [Parameter]
    public required string EventName { get; set; }

    [Parameter]
    public required string Year { get; set; }

    [Parameter]
    public required string PhotoName { get; set; }

    public string Image()
    {
        return new ConfigurationBuilder().AddJsonFile("content/eventphotos.json").Build().GetSection($"Events:{EventName}:{Year}")[$"{PhotoName}"];
    }
}