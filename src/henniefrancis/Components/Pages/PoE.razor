@inherits BlogModel
@page "/poe"

<div class="row">
    <div class="col-auto">
        <a href="/" class="button" title="Back"><img alt="back" src="@Config.Images.General.Back" class="button img-fluid" title="Back" /></a>
    </div>
    <div class="col">
        <div class="pagetitle">
            <h1>Portfolio of Evidence</h1>
            <hr class="pagedivider" />
            @* <a href="https://1drv.ms/b/s!AvgfjliGfehWgeEZUQryJVUvdCHBIQ?e=1hf0Q7" class="btn btn-outline-info" target="_blank">Download Portfolio of Evidence</a> *@
        </div>
    </div>
</div>

<div class="container-fluid" style="margin-top: 0px;">
