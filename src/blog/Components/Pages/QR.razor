@code {
    public QRCodeGenerator qr { get; set; }
    public QRCodeData qrData { get; set; }
    public BitmapByteQRCode qrCode { get; set; }
    public string qrCodeImage { get; set; }


    public string QRCode_WebLink(string link)
    {
        var payload = new PayloadGenerator.Url(link);


        qr = new();
        qrData = qr.CreateQrCode(payload);

        qrCode = new(qrData);

        qrCodeImage = $"data:image/png;base64,{Convert.ToBase64String(qrCode.GetGraphic(20))}";
        // use this when you want to show your logo in middle of QR Code and change color of qr code
        //var qrCodeAsBitmap = qrCode.GetGraphic(20, Color.Black, Color.Red, logoImage);
             

        return qrCodeImage;
    }
}