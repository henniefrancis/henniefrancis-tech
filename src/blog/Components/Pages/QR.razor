@using System;
@using QRCoder;
@using System.Drawing

@page "/qr"

<div class="row">
    <div class="col-auto">
        <a href="/" class="button" title="Back"><img alt="back" src="@Config.Images.General.Back" class="button img-fluid" title="Back" /></a>
    </div>
    <div class="col">
        <div class="pagetitle">
            <h1>QR Codes</h1>
            <hr class="pagedivider" />
        </div>
    </div>
</div>

<div class="spacer"></div>

<div class="row">
    <div class="col-sm-3">
        <a href="@Config.Links.Blog" title="Hennie Francis" target="_blank" class="blanklink">
            <div class="mt-4 p-5 bg-gradient text-white rounded text-center ">
                <h4>Website</h4>
                <p>Hennie Francis</p>
                <hr />
                <img src="@QRCode_WebLink(Config.Links.Blog)" title="Hennie Francis: Website" alt="Hennie Francis: Website" class="img-fluid" />
            </div>
        </a>
    </div>
    <div class="col-sm-3">
        <a href="@Config.Links.GitHubProject" title="GitHub: .NET Conference 2023" target="_blank" class="blanklink">
            <div class="mt-4 p-5 bg-gradient text-white rounded text-center ">
                <h4>GitHub</h4>
                <p>.NET Conference 2023</p>
                <hr />
                <img src="@QRCode_WebLink(Config.Links.GitHubProject)" title="GitHub Project: .NET Conference 2023" alt="GitHub Project: .NET Conference 2023" class="img-fluid" />
            </div>
        </a>
    </div>
</div>



@code {
    public QRCodeGenerator qr { get; set; }
    public QRCodeData qrData { get; set; }
    public BitmapByteQRCode qrCode { get; set; }
    public string qrCodeImage { get; set; }


    public string QRCode_WebLink(string link)
    {
        var payload = new PayloadGenerator.Url(link);


        qr = new();
        qrData = qr.CreateQrCode(payload);

        qrCode = new(qrData);

        qrCodeImage = $"data:image/png;base64,{Convert.ToBase64String(qrCode.GetGraphic(20))}";
        // use this when you want to show your logo in middle of QR Code and change color of qr code
        //var qrCodeAsBitmap = qrCode.GetGraphic(20, Color.Black, Color.Red, logoImage);
             

        return qrCodeImage;
    }
}