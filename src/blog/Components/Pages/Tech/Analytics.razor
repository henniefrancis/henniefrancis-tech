@page "/techstack/analytics"

<div class="row">
    <div class="col-auto">
        <a href="/techstack" class="button" title="Back"><img alt="back" src="@Config.Images.General.Back" class="button img-fluid" title="Back" /></a>
    </div>
    <div class="col">
        <div class="pagetitle">
            <h1>Tech Stack: Analytics</h1>
            <hr class="pagedivider" />
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-sm-1">
            <a href="@Config.Tech.Links.Analytics.Google" title="Google Analytics" target="_blank" class="blanklink">
                <div class="mt-1 p-1 text-white rounded text-center ">
                    <img alt="Google Analytics" src="@Config.Images.TechStack.Analytics.Google" class="img-fluid" title="Google Analytics" />
                </div>
            </a>
        </div>
        <div class="col-sm-1">
            <a href="@Config.Tech.Links.Analytics.PowerBI" title="Microsoft Power BI" target="_blank" class="blanklink">
                <div class="mt-1 p-1 text-white rounded text-center ">
                    <img alt="Microsoft Power BI" src="@Config.Images.TechStack.Analytics.PowerBI" class="img-fluid" title="Microsoft Power BI" />
                </div>
            </a>
        </div>
        <div class="col-sm-1">
            <a href="@Config.Tech.Links.Analytics.OLAP" title="OLAP Cubes" target="_blank" class="blanklink">
                <div class="mt-1 p-1 text-white rounded text-center ">
                    <img alt="OLAP Cubes" src="@Config.Images.TechStack.Analytics.OLAP" class="img-fluid" title="OLAP Cubes" />
                </div>
            </a>
        </div>
    </div>
</div>