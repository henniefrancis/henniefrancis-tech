@code {
    public string EmployeePeriod()
    {
        DateTime StartDate = new DateTime(2022, 7, 1);

        // Define the start and end dates.
        DateTime startDate = new DateTime(2022, 7, 1); // Change this to your start date.
        DateTime endDate = DateTime.Now; // Change this to your end date.

        // Calculate the time span between the start and end dates.
        TimeSpan timeSpan = endDate - startDate;

        // Calculate years, months, and days.
        int years = timeSpan.Days / 365;
        int months = (timeSpan.Days % 365) / 30;
        int days = ((timeSpan.Days % 365) % 30)-1;

        string year = years > 1 ? years + " Years" : years + " Year";
        string month = months > 1 ? months + " Months" : months + " Month";
        string day = days > 1 ? days + " Days" : days + " Day";

        return ($"{year}, {month}, {day}");
    }
}